    "dotenv": "^16.6.1",
    "grammy": "^1.38.1",
    "hono": "^4.9.6",
    "https-proxy-agent": "^9.1.0",
    "jose": "^6.2.3",
    "qrcode": "^1.5.4",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
