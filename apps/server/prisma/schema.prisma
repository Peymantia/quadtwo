generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  partner
  wholesale
  admin
}

enum OrderStatus {
  pending_payment
  awaiting_review
  paid
  provisioning
  completed
  rejected
  cancelled
}

enum PaymentMethod {
  card_to_card
  wallet
  online_soon
  crypto_soon
}

enum OrderKind {
  new
  renew
  rotate_sub
  rotate_uuid
  wallet_charge
}

enum WalletTxType {
  charge
  purchase
  refund
  adjust
}

enum SubscriptionStatus {
  active
  expired
  disabled
}

model User {
  id            String    @id @default(cuid())
  telegramId    BigInt    @unique
  username      String?
  firstName     String?
  lastName      String?
  role          UserRole  @default(user)
  /// Display name of reseller/admin agent (required for dedicated panel group)
  agentName     String?
  panelGroup    String?
  /// When user claimed the free 1-day / 250MB test account
  testClaimedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  wallet         Wallet?
  orders         Order[]
  subscriptions  Subscription[]
  partnerRequest PartnerRequest?
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  txs       WalletTransaction[]
}

model WalletTransaction {
  id            String       @id @default(cuid())
  walletId      String
  type          WalletTxType
  amount        Int
  balanceBefore Int
  balanceAfter  Int
  note          String?
  createdAt     DateTime     @default(now())
  wallet        Wallet       @relation(fields: [walletId], references: [id])
}

model Plan {
  id            String   @id @default(cuid())
  title         String
  trafficGb     Int?
  durationDays  Int
  priceUser     Int
  pricePartner  Int
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]
}

/// Manual price matrix: trafficGb null = unlimited
model PriceCell {
  id             String  @id @default(cuid())
  title          String?
  /// data | national | unlimited
  category       String  @default("data")
  trafficGb      Int?
  months         Int
  priceUser      Int
  pricePartner   Int
  priceWholesale Int     @default(0)
  isGolden       Boolean @default(false)
  active         Boolean @default(true)
  sortOrder      Int     @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([category, months])
}

model PanelServer {
  id           String   @id @default(cuid())
  name         String
  baseUrl      String
  apiTokenEnc  String
  inboundId    Int
  active       Boolean  @default(true)
  sellEnabled  Boolean  @default(true)
  weight       Int      @default(100)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  subscriptions Subscription[]
}

model Order {
  id              String        @id @default(cuid())
  userId          String
  planId          String?
  kind            OrderKind     @default(new)
  trafficGb       Int?
  months          Int           @default(1)
  price           Int
  status          OrderStatus   @default(pending_payment)
  paymentMethod   PaymentMethod @default(card_to_card)
  receiptFileId   String?
  receiptText     String?
  adminNote       String?
  accountName     String?
  customName      String?
  quantity        Int           @default(1)
  /// Max simultaneous IPs/devices (0 = unlimited)
  limitIp         Int           @default(0)
  targetSubId     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id])
  plan            Plan?         @relation(fields: [planId], references: [id])
  subscription    Subscription?
  targetSub       Subscription? @relation("OrderTargetSub", fields: [targetSubId], references: [id])
}

model Subscription {
  id              String             @id @default(cuid())
  code            String             @unique
  userId          String
  orderId         String?            @unique
  panelServerId   String?
  title           String?
  email           String
  clientUuid      String?
  panelSubId      String?
  trafficGb       Int?
  /// When true, panel expiry is "start after first connect" (negative ms)
  startsOnConnect Boolean            @default(true)
  activatedAt     DateTime?
  /// Free test account (1 day / 250MB)
  isTest          Boolean            @default(false)
  expiresAt       DateTime
  subUrl          String?
  status          SubscriptionStatus @default(active)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id])
  order           Order?             @relation(fields: [orderId], references: [id])
  panelServer     PanelServer?       @relation(fields: [panelServerId], references: [id])
  renewOrders     Order[]            @relation("OrderTargetSub")
}

model PartnerRequest {
  id        String   @id @default(cuid())
  userId    String   @unique
  fullName  String
  phone     String?
  note      String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Dedupe log so expiry/traffic alerts are not spammed every cron tick
model NotificationLog {
  id             String   @id @default(cuid())
  subscriptionId String
  kind           String
  bucket         String
  createdAt      DateTime @default(now())

  @@unique([subscriptionId, kind, bucket])
  @@index([subscriptionId])
}

/// Simple audit trail for admin debugging
model AuditLog {
  id               String   @id @default(cuid())
  action           String
  actorTelegramId  BigInt?
  target           String?
  detail           String?
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([action])
}

/// Temporary buy wizard state per telegram user
model BuyDraft {
  id          String   @id @default(cuid())
  telegramId  BigInt   @unique
  trafficGb   Int?     @default(10)
  months      Int      @default(1)
  unlimited   Boolean  @default(false)
  quantity    Int      @default(1)
  /// Max IPs for new purchase (0 = unlimited)
  limitIp     Int      @default(0)
  category    String   @default("data")
  accountMode String   @default("random")
  accountName String?
  updatedAt   DateTime @updatedAt
}
