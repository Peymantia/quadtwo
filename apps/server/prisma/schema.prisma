generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  partner
  wholesale
  admin
}

enum OrderStatus {
  pending_payment
  awaiting_review
  paid
  provisioning
  completed
  rejected
  cancelled
}

enum PaymentMethod {
  card_to_card
  wallet
  online_soon
  crypto_soon
}

enum OrderKind {
  new
  renew
  rotate_sub
  rotate_uuid
  wallet_charge
}

enum WalletTxType {
  charge
  purchase
  refund
  adjust
}

enum SubscriptionStatus {
  active
  expired
  disabled
}

model User {
  id            String    @id @default(cuid())
  telegramId    BigInt    @unique
  username      String?
  firstName     String?
  lastName      String?
  role          UserRole  @default(user)
  /// Display name of reseller/admin agent (required for dedicated panel group)
  agentName     String?
  panelGroup    String?
  /// When user claimed the free 1-day / 250MB test account
  testClaimedAt DateTime?
  /// scrypt hash for web dashboard password login
  passwordHash  String?
  passwordSetAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  wallet         Wallet?
  orders         Order[]
  subscriptions  Subscription[]
  partnerRequest PartnerRequest?
  agentRenames   AgentRenameRequest[]
  loginOtps      LoginOtp[]
  webAuthnCreds  WebAuthnCredential[]
}

/// WebAuthn / Passkey credentials for dashboard biometric login
model WebAuthnCredential {
  id           String    @id @default(cuid())
  userId       String
  /// base64url credential id
  credentialId String    @unique
  /// base64url public key
  publicKey    String
  counter      BigInt    @default(0)
  /// JSON array of transports e.g. ["internal","hybrid"]
  transports   String?
  deviceType   String?
  backedUp     Boolean   @default(false)
  label        String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// One-time codes for dash.anthropics.ir login (Telegram delivery)
model LoginOtp {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String
  attempts  Int      @default(0)
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  txs       WalletTransaction[]
}

model WalletTransaction {
  id            String       @id @default(cuid())
  walletId      String
  type          WalletTxType
  amount        Int
  balanceBefore Int
  balanceAfter  Int
  note          String?
  createdAt     DateTime     @default(now())
  wallet        Wallet       @relation(fields: [walletId], references: [id])
}

model Plan {
  id            String   @id @default(cuid())
  title         String
  trafficGb     Int?
  durationDays  Int
  priceUser     Int
  pricePartner  Int
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]
}

/// Manual price matrix: trafficGb null = unlimited
model PriceCell {
  id             String  @id @default(cuid())
  title          String?
  /// data | national | unlimited
  category       String  @default("data")
  trafficGb      Int?
  months         Int
  priceUser      Int
  pricePartner   Int
  priceWholesale Int     @default(0)
  isGolden       Boolean @default(false)
  active         Boolean @default(true)
  sortOrder      Int     @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([category, months])
}

model PanelServer {
  id          String   @id @default(cuid())
  /// Display name e.g. "سرور اصلی" / "نت ملی"
  name        String
  baseUrl     String
  /// API bearer token (plain in v1, same trust model as .env)
  apiToken    String
  /// Comma / range inbound ids, e.g. "1,2,3"
  inboundIds  String   @default("1")
  /// Optional subscription URL base override (like XUI_SUB_BASE)
  subBase     String?
  /// JSON array of categories this panel serves: ["data","national","unlimited"]
  categories  String   @default("[\"data\",\"unlimited\"]")
  active      Boolean  @default(true)
  sellEnabled Boolean  @default(true)
  weight      Int      @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  subscriptions Subscription[]
  orders        Order[]
}

model Order {
  id              String        @id @default(cuid())
  userId          String
  planId          String?
  kind            OrderKind     @default(new)
  trafficGb       Int?
  months          Int           @default(1)
  price           Int
  status          OrderStatus   @default(pending_payment)
  paymentMethod   PaymentMethod @default(card_to_card)
  receiptFileId   String?
  receiptText     String?
  adminNote       String?
  accountName     String?
  customName      String?
  /// User-facing memo copied onto the subscription at provision
  note            String?
  quantity        Int           @default(1)
  /// Max simultaneous IPs/devices (0 = unlimited)
  limitIp         Int           @default(0)
  /// Resolved panel for this purchase (category routing)
  panelServerId   String?
  targetSubId     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id])
  plan            Plan?         @relation(fields: [planId], references: [id])
  panelServer     PanelServer?  @relation(fields: [panelServerId], references: [id])
  subscription    Subscription?
  targetSub       Subscription? @relation("OrderTargetSub", fields: [targetSubId], references: [id])
}

model Subscription {
  id              String             @id @default(cuid())
  code            String             @unique
  userId          String
  orderId         String?            @unique
  panelServerId   String?
  title           String?
  email           String
  clientUuid      String?
  panelSubId      String?
  trafficGb       Int?
  /// When true, panel expiry is "start after first connect" (negative ms)
  startsOnConnect Boolean            @default(true)
  activatedAt     DateTime?
  /// Free test account (1 day / 250MB)
  isTest          Boolean            @default(false)
  expiresAt       DateTime
  subUrl          String?
  /// User-facing memo / note for this service
  note            String?
  status          SubscriptionStatus @default(active)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id])
  order           Order?             @relation(fields: [orderId], references: [id])
  panelServer     PanelServer?       @relation(fields: [panelServerId], references: [id])
  renewOrders     Order[]            @relation("OrderTargetSub")
}

model PartnerRequest {
  id        String   @id @default(cuid())
  userId    String   @unique
  fullName  String
  phone     String?
  note      String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

/// Partner/reseller asked to change display name + panel group (needs admin approval)
model AgentRenameRequest {
  id        String   @id @default(cuid())
  userId    String
  oldName   String
  oldGroup  String
  newName   String
  newGroup  String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Dedupe log so expiry/traffic alerts are not spammed every cron tick
model NotificationLog {
  id             String   @id @default(cuid())
  subscriptionId String
  kind           String
  bucket         String
  createdAt      DateTime @default(now())

  @@unique([subscriptionId, kind, bucket])
  @@index([subscriptionId])
}

/// Simple audit trail for admin debugging
model AuditLog {
  id               String   @id @default(cuid())
  action           String
  actorTelegramId  BigInt?
  target           String?
  detail           String?
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([action])
}

/// Temporary buy wizard state per telegram user
model BuyDraft {
  id          String   @id @default(cuid())
  telegramId  BigInt   @unique
  trafficGb   Int?     @default(10)
  months      Int      @default(1)
  unlimited   Boolean  @default(false)
  quantity    Int      @default(1)
  /// Max IPs for new purchase (0 = unlimited)
  limitIp         Int      @default(0)
  /// User explicitly changed IP limit in wizard (0 then means unlimited)
  limitIpTouched  Boolean  @default(false)
  category    String   @default("data")
  accountMode String   @default("random")
  accountName String?
  updatedAt   DateTime @updatedAt
}
