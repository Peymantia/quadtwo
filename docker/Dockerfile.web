FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json* ./
COPY apps/web/package.json apps/web/
COPY packages/shared/package.json packages/shared/
RUN npm install --workspace=@quadtwo/web --workspace=@quadtwo/shared --include-workspace-root=false

FROM node:22-alpine AS build
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY package.json ./
COPY packages/shared packages/shared
COPY apps/web apps/web
RUN npm run build -w @quadtwo/shared && npm run build -w @quadtwo/web

FROM node:22-alpine
WORKDIR /app
ENV NODE_ENV=production
COPY --from=build /app/packages/shared /app/packages/shared
COPY --from=build /app/apps/web /app/apps/web
COPY --from=build /app/node_modules /app/node_modules
COPY package.json ./
EXPOSE 3000
CMD ["npm", "run", "start", "-w", "@quadtwo/web"]
