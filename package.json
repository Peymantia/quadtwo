{
  "name": "quadtwo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @quadtwo/server",
    "dev:web": "npm run dev -w @quadtwo/web",
    "build": "npm run build -w @quadtwo/shared && npm run build -w @quadtwo/server && npm run build -w @quadtwo/web",
    "db:generate": "npm run db:generate -w @quadtwo/server",
    "db:migrate": "npm run db:migrate -w @quadtwo/server",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=22"
  }
}
