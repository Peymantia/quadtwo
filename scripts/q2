#!/usr/bin/env bash
# QuadTwo (Q2) management CLI
# Usage:
#   q2                 # interactive menu
#   q2 start|stop|…    # direct command
#   quadtwo …          # same binary (symlink)
set -euo pipefail

SERVICE="${QUADTWO_SERVICE:-quadtwo}"
WEB_SERVICE="${SERVICE}-web"
DIR="${QUADTWO_DIR:-/opt/quadtwo}"

RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
DIM=$'\033[2m'
NC=$'\033[0m'

has_web() { systemctl list-unit-files "${WEB_SERVICE}.service" &>/dev/null; }

svc_start() {
  systemctl start "$SERVICE"
  has_web && systemctl start "$WEB_SERVICE" || true
  echo -e "${GREEN}Started${NC} ${SERVICE}${has_web:+ + ${WEB_SERVICE}}"
}

svc_stop() {
  has_web && systemctl stop "$WEB_SERVICE" || true
  systemctl stop "$SERVICE"
  echo -e "${YELLOW}Stopped${NC} ${SERVICE}${has_web:+ + ${WEB_SERVICE}}"
}

svc_restart() {
  systemctl restart "$SERVICE"
  has_web && systemctl restart "$WEB_SERVICE" || true
  echo -e "${GREEN}Restarted${NC} ${SERVICE}${has_web:+ + ${WEB_SERVICE}}"
}

svc_status() {
  systemctl status "$SERVICE" --no-pager || true
  if has_web; then
    echo
    systemctl status "$WEB_SERVICE" --no-pager || true
  fi
}

svc_logs() {
  if has_web; then
    journalctl -u "$SERVICE" -u "$WEB_SERVICE" -f -n 100
  else
    journalctl -u "$SERVICE" -f -n 100
  fi
}

env_file() { echo "$DIR/.env"; }

env_get() {
  local key="$1" file
  file="$(env_file)"
  [[ -f "$file" ]] || return 1
  grep -E "^${key}=" "$file" | tail -n1 | cut -d= -f2- | tr -d '\r'
}

set_env_key() {
  local key="$1" value="$2" file tmp
  file="$(env_file)"
  [[ -f "$file" ]] || { echo "No .env at $file"; exit 1; }
  tmp="$(mktemp)"
  grep -v -E "^${key}=" "$file" > "$tmp" || true
  printf '%s=%s\n' "$key" "$value" >> "$tmp"
  mv "$tmp" "$file"
  chmod 600 "$file"
}

telegram_get_me() {
  local token="$1" proxy args=(-fsS --max-time 15)
  proxy="$(env_get TELEGRAM_PROXY 2>/dev/null || true)"
  [[ -n "$proxy" ]] && args+=(-x "$proxy")
  curl "${args[@]}" "https://api.telegram.org/bot${token}/getMe"
}

do_update() {
  bash <(curl -Ls https://raw.githubusercontent.com/Peymantia/quadtwo/main/install.sh) --update
}

do_env() {
  ${EDITOR:-nano} "$(env_file)"
}

do_set_token() {
  local TOKEN="${1:-}"
  local ENV_FILE ME_JSON BOT_USER BOT_NAME DOMAIN PATH_HOOK WEBHOOK_URL
  ENV_FILE="$(env_file)"
  [[ -f "$ENV_FILE" ]] || { echo "No .env at $ENV_FILE"; exit 1; }
  if [[ -z "$TOKEN" ]]; then
    read -r -p "New BOT_TOKEN from BotFather: " TOKEN
  fi
  TOKEN="$(echo "$TOKEN" | tr -d '[:space:]')"
  [[ -n "$TOKEN" ]] || { echo "BOT_TOKEN is required."; exit 1; }
  if [[ ! "$TOKEN" =~ ^[0-9]+:[A-Za-z0-9_-]+$ ]]; then
    echo "Token format looks invalid (expected 123456789:ABC...)."
    exit 1
  fi
  echo "Validating token with Telegram..."
  ME_JSON="$(telegram_get_me "$TOKEN")" || {
    echo "Telegram rejected this token (network or invalid token)."
    exit 1
  }
  BOT_USER="$(echo "$ME_JSON" | grep -o '"username":"[^"]*"' | head -1 | cut -d'"' -f4 || true)"
  BOT_NAME="$(echo "$ME_JSON" | grep -o '"first_name":"[^"]*"' | head -1 | cut -d'"' -f4 || true)"
  set_env_key BOT_TOKEN "$TOKEN"
  echo "BOT_TOKEN updated in $ENV_FILE"
  if [[ "$(env_get BOT_MODE)" == "webhook" ]]; then
    DOMAIN="$(env_get PUBLIC_DOMAIN)"
    PATH_HOOK="$(env_get TELEGRAM_WEBHOOK_PATH)"
    PATH_HOOK="${PATH_HOOK:-/telegram/webhook}"
    if [[ -n "$DOMAIN" ]]; then
      WEBHOOK_URL="https://${DOMAIN}${PATH_HOOK}"
      echo "Setting webhook: $WEBHOOK_URL"
      curl -fsS --max-time 15 \
        "https://api.telegram.org/bot${TOKEN}/setWebhook" \
        -d "url=${WEBHOOK_URL}" >/dev/null \
        || echo "Warning: setWebhook failed — check PUBLIC_DOMAIN and HTTPS."
    else
      echo "Warning: BOT_MODE=webhook but PUBLIC_DOMAIN is empty."
    fi
  fi
  echo "Restarting services..."
  svc_restart
  sleep 1
  if [[ -n "$BOT_USER" ]]; then
    echo "Done. New bot: @${BOT_USER}${BOT_NAME:+ ($BOT_NAME)}"
  else
    echo "Done. Service restarted."
  fi
  echo "Users must open the new bot and send /start."
}

do_set_admin() {
  local IDS="${1:-}" OLD_IDS ENV_FILE
  ENV_FILE="$(env_file)"
  [[ -f "$ENV_FILE" ]] || { echo "No .env at $ENV_FILE"; exit 1; }
  if [[ -z "$IDS" ]]; then
    echo "Current ADMIN_TELEGRAM_IDS: $(env_get ADMIN_TELEGRAM_IDS || echo '(empty)')"
    read -r -p "New admin Telegram numeric ID(s), comma-separated: " IDS
  fi
  IDS="$(echo "$IDS" | tr -d '[:space:]' | tr -d '@')"
  [[ -n "$IDS" ]] || { echo "Admin Telegram ID is required."; exit 1; }
  if [[ ! "$IDS" =~ ^[0-9]+(,[0-9]+)*$ ]]; then
    echo "Invalid ID list (expected numeric IDs like 123456789 or 111,222)."
    exit 1
  fi
  OLD_IDS="$(env_get ADMIN_TELEGRAM_IDS || true)"
  set_env_key ADMIN_TELEGRAM_IDS "$IDS"
  echo "ADMIN_TELEGRAM_IDS: ${OLD_IDS:-'(empty)'} → $IDS"
  echo "Syncing database roles..."
  (
    cd "$DIR"
    set -a
    # shellcheck disable=SC1091
    source "$ENV_FILE"
    set +a
    if [[ -x "$DIR/node_modules/.bin/tsx" ]]; then
      "$DIR/node_modules/.bin/tsx" apps/server/scripts/set-admin.ts "$IDS"
    elif command -v npx >/dev/null 2>&1; then
      npx --yes tsx apps/server/scripts/set-admin.ts "$IDS"
    else
      echo "Warning: tsx not found — .env updated but DB roles were not synced."
      echo "Run manually: cd $DIR && npx tsx apps/server/scripts/set-admin.ts $IDS"
    fi
  ) || {
    echo "Warning: DB sync failed — .env was still updated."
    echo "Fix DB with: cd $DIR && npx tsx apps/server/scripts/set-admin.ts $IDS"
  }
  echo "Restarting services..."
  svc_restart
  sleep 1
  echo "Done. New admin(s): $IDS"
  echo "Open the bot from the new Telegram account and send /start."
  echo "Old Telegram accounts are no longer control admins."
}

do_license_status() {
  echo -e "${BOLD}License status${NC}"
  echo "  DEMO_MODE:          $(env_get DEMO_MODE 2>/dev/null || echo '(empty)')"
  echo "  LICENSE_REQUIRE:    $(env_get LICENSE_REQUIRE 2>/dev/null || echo '(empty)')"
  echo "  LICENSE_KEY:        $( [[ -n "$(env_get LICENSE_KEY 2>/dev/null || true)" ]] && echo '(set)' || echo '(empty)' )"
  echo "  LICENSE_ADMIN_IDS:  $(env_get LICENSE_ADMIN_IDS 2>/dev/null || echo '(empty)')"
  echo "  LICENSE_DASH_HOST:  $(env_get LICENSE_DASH_HOST 2>/dev/null || echo '(empty)')"
  echo "  ADMIN_TELEGRAM_IDS: $(env_get ADMIN_TELEGRAM_IDS 2>/dev/null || echo '(empty)')"
  echo "  DASH_DOMAIN:        $(env_get DASH_DOMAIN 2>/dev/null || echo '(empty)')"
  if [[ -x "$DIR/node_modules/.bin/tsx" ]] || command -v npx >/dev/null 2>&1; then
    (
      cd "$DIR"
      set -a
      # shellcheck disable=SC1091
      source "$(env_file)" 2>/dev/null || true
      set +a
      if [[ -x "$DIR/node_modules/.bin/tsx" ]]; then
        "$DIR/node_modules/.bin/tsx" -e "import { getLicenseStatus } from './apps/server/src/services/license.ts'; const s=getLicenseStatus(); console.log('  verify:', JSON.stringify(s));"
      else
        npx --yes tsx -e "import { getLicenseStatus } from './apps/server/src/services/license.ts'; const s=getLicenseStatus(); console.log('  verify:', JSON.stringify(s));"
      fi
    ) 2>/dev/null || echo "  (runtime verify skipped — start the server to validate)"
  fi
}

demo_mode_on() {
  local v
  v="$(env_get DEMO_MODE 2>/dev/null || true)"
  v="$(echo "$v" | tr '[:upper:]' '[:lower:]')"
  [[ "$v" == "1" || "$v" == "true" || "$v" == "yes" ]]
}

do_demo_status() {
  local token me bot_user bot_name
  echo -e "${BOLD}Demo Bot status${NC}"
  echo
  if demo_mode_on; then
    echo -e "  Mode:   ${GREEN}ON${NC}  (DEMO_MODE=true)"
  else
    echo -e "  Mode:   ${DIM}OFF${NC}  (DEMO_MODE=$(env_get DEMO_MODE 2>/dev/null || echo empty))"
  fi
  echo "  Admins: $(env_get ADMIN_TELEGRAM_IDS 2>/dev/null || echo '(empty)')"
  echo "  Dash:   $(env_get DASH_DOMAIN 2>/dev/null || echo '(empty)')"
  token="$(env_get BOT_TOKEN 2>/dev/null || true)"
  if [[ -n "$token" ]]; then
    echo -n "  Bot:    "
    me="$(telegram_get_me "$token" 2>/dev/null || true)"
    if [[ -n "$me" ]]; then
      bot_user="$(echo "$me" | grep -o '"username":"[^"]*"' | head -1 | cut -d'"' -f4 || true)"
      bot_name="$(echo "$me" | grep -o '"first_name":"[^"]*"' | head -1 | cut -d'"' -f4 || true)"
      if [[ -n "$bot_user" ]]; then
        echo "@${bot_user}${bot_name:+ ($bot_name)}"
      else
        echo "(token set — could not parse getMe)"
      fi
    else
      echo "(token set — Telegram unreachable / invalid)"
    fi
  else
    echo "  Bot:    (no BOT_TOKEN)"
  fi
  echo
  if demo_mode_on; then
    echo -e "${DIM}In Telegram: «تغییر نقش دمو» — switch admin / partner / wholesale / user.${NC}"
    echo -e "${DIM}In web dash: yellow bar at top — same role switch.${NC}"
    echo -e "${DIM}License checks are skipped while DEMO_MODE is on.${NC}"
  else
    echo -e "${DIM}Enable with: q2 demo enable${NC}"
  fi
}

do_demo_enable() {
  local TOKEN="${1:-}" IDS="${2:-}" ENV_FILE ans
  ENV_FILE="$(env_file)"
  [[ -f "$ENV_FILE" ]] || { echo "No .env at $ENV_FILE"; exit 1; }

  echo -e "${BOLD}Enable Demo Bot${NC}"
  echo
  echo "One install = one bot. Demo is the same QuadTwo with DEMO_MODE=true"
  echo "(role switcher in bot + web; license skipped). Use a separate VPS"
  echo "or BotFather bot for demos — do not enable on a paid customer install."
  echo
  do_demo_status
  echo

  if [[ -z "$TOKEN" ]]; then
    read -r -p "BOT_TOKEN for demo (Enter = keep current): " TOKEN || true
  fi
  TOKEN="$(echo "${TOKEN:-}" | tr -d '[:space:]')"
  if [[ -n "$TOKEN" ]]; then
    if [[ ! "$TOKEN" =~ ^[0-9]+:[A-Za-z0-9_-]+$ ]]; then
      echo "Token format looks invalid (expected 123456789:ABC...)."
      exit 1
    fi
    echo "Validating token with Telegram..."
    telegram_get_me "$TOKEN" >/dev/null || {
      echo "Telegram rejected this token (network or invalid token)."
      exit 1
    }
    set_env_key BOT_TOKEN "$TOKEN"
    echo "BOT_TOKEN updated."
  fi

  if [[ -z "$IDS" ]]; then
    echo "Current ADMIN_TELEGRAM_IDS: $(env_get ADMIN_TELEGRAM_IDS || echo '(empty)')"
    read -r -p "Demo admin Telegram ID(s), comma-separated (Enter = keep): " IDS || true
  fi
  IDS="$(echo "${IDS:-}" | tr -d '[:space:]' | tr -d '@')"
  if [[ -n "$IDS" ]]; then
    if [[ ! "$IDS" =~ ^[0-9]+(,[0-9]+)*$ ]]; then
      echo "Invalid ID list (expected numeric IDs like 123456789)."
      exit 1
    fi
    set_env_key ADMIN_TELEGRAM_IDS "$IDS"
    echo "ADMIN_TELEGRAM_IDS → $IDS"
    (
      cd "$DIR"
      set -a
      # shellcheck disable=SC1091
      source "$ENV_FILE"
      set +a
      if [[ -x "$DIR/node_modules/.bin/tsx" ]]; then
        "$DIR/node_modules/.bin/tsx" apps/server/scripts/set-admin.ts "$IDS"
      elif command -v npx >/dev/null 2>&1; then
        npx --yes tsx apps/server/scripts/set-admin.ts "$IDS"
      fi
    ) || echo "Warning: DB admin sync failed — .env was still updated."
  fi

  set_env_key DEMO_MODE "true"
  echo -e "DEMO_MODE → ${GREEN}true${NC}"
  echo "Restarting services..."
  svc_restart
  sleep 1
  echo
  do_demo_status
  echo
  echo "Done. Open the bot and send /start — use «تغییر نقش دمو»."
}

do_demo_disable() {
  local ENV_FILE ans
  ENV_FILE="$(env_file)"
  [[ -f "$ENV_FILE" ]] || { echo "No .env at $ENV_FILE"; exit 1; }
  if ! demo_mode_on; then
    echo "Demo mode is already off."
    return 0
  fi
  echo "This turns off the role switcher (bot + web). License rules apply again if configured."
  read -r -p "Disable DEMO_MODE? [y/N]: " ans || true
  case "${ans:-}" in
    y|Y|yes|YES) ;;
    *) echo "Cancelled."; return 0 ;;
  esac
  set_env_key DEMO_MODE "false"
  echo -e "DEMO_MODE → ${YELLOW}false${NC}"
  echo "Restarting services..."
  svc_restart
  sleep 1
  echo "Done. Demo role switcher is off."
}

demo_menu() {
  local choice tok ids
  while true; do
    clear 2>/dev/null || true
    cat <<EOF
${BOLD}${CYAN}╔══════════════════════════╗
║   Demo Bot               ║
╚══════════════════════════╝${NC}
${DIM}Same install · DEMO_MODE flag · role switcher${NC}

EOF
    do_demo_status
    cat <<EOF

  ${GREEN}1${NC}) status
  ${GREEN}2${NC}) enable   ${DIM}(DEMO_MODE=true + optional token/admin)${NC}
  ${GREEN}3${NC}) disable  ${DIM}(DEMO_MODE=false)${NC}
  ${GREEN}4${NC}) set-token ${DIM}(demo bot from BotFather)${NC}
  ${GREEN}5${NC}) set-admin ${DIM}(who can open control)${NC}
  ${YELLOW}0${NC}) back

EOF
    read -r -p "Select [0-5]: " choice || true
    case "${choice:-}" in
      1) do_demo_status; pause ;;
      2) do_demo_enable; pause ;;
      3) do_demo_disable; pause ;;
      4)
        read -r -p "BOT_TOKEN (Enter to prompt): " tok || true
        do_set_token "${tok:-}"
        pause
        ;;
      5)
        read -r -p "Admin ID(s) (Enter to prompt): " ids || true
        do_set_admin "${ids:-}"
        pause
        ;;
      0|b|B|back) return 0 ;;
      *)
        echo "Invalid option."
        pause
        ;;
    esac
  done
}

do_demo() {
  local sub="${1:-}"
  shift || true
  case "${sub}" in
    ""|menu) demo_menu ;;
    status|st) do_demo_status ;;
    enable|on|true) do_demo_enable "${1:-}" "${2:-}" ;;
    disable|off|false) do_demo_disable ;;
    help|-h|--help)
      cat <<EOF
${BOLD}q2 demo${NC} — manage DEMO_MODE showcase bot

  q2 demo              Interactive Demo Bot menu
  q2 demo status       Show DEMO_MODE + bot
  q2 demo enable       Turn on DEMO_MODE (optional token / admin)
  q2 demo disable      Turn off DEMO_MODE

.env essentials:
  DEMO_MODE=true
  BOT_TOKEN=123456:ABC...     # BotFather token for the demo bot
  ADMIN_TELEGRAM_IDS=111,222  # who controls / can switch roles
  DASH_DOMAIN=dash.example.com
EOF
      ;;
    *)
      echo "Unknown demo subcommand: $sub"
      echo "Try: q2 demo help"
      exit 1
      ;;
  esac
}

do_activate() {
  local KEY="${1:-}" ENV_FILE HOST ADMINS PARSED
  ENV_FILE="$(env_file)"
  [[ -f "$ENV_FILE" ]] || { echo "No .env at $ENV_FILE"; exit 1; }
  if [[ -z "$KEY" ]]; then
    echo "Paste the license key from the seller (Q2.1.…):"
    read -r KEY
  fi
  KEY="$(echo "$KEY" | tr -d '[:space:]')"
  [[ -n "$KEY" ]] || { echo "LICENSE_KEY is required."; exit 1; }
  if [[ ! "$KEY" =~ ^Q2\.1\. ]]; then
    echo "Key format looks invalid (expected Q2.1.…)."
    exit 1
  fi

  echo "Validating license…"
  PARSED="$(
    cd "$DIR"
    set -a
    # shellcheck disable=SC1091
    source "$ENV_FILE" 2>/dev/null || true
    set +a
    if [[ -x "$DIR/node_modules/.bin/tsx" ]]; then
      "$DIR/node_modules/.bin/tsx" -e "
        import { parseLicenseKey } from './apps/server/src/services/license.ts';
        const r = parseLicenseKey(process.argv[1]);
        if (!r.ok) { console.error(r.reason); process.exit(2); }
        console.log(r.payload.admins + '|' + r.payload.host);
      " "$KEY"
    else
      npx --yes tsx -e "
        import { parseLicenseKey } from './apps/server/src/services/license.ts';
        const r = parseLicenseKey(process.argv[1]);
        if (!r.ok) { console.error(r.reason); process.exit(2); }
        console.log(r.payload.admins + '|' + r.payload.host);
      " "$KEY"
    fi
  )" || {
    echo "License validation failed."
    exit 1
  }
  ADMINS="${PARSED%%|*}"
  HOST="${PARSED#*|}"
  [[ -n "$ADMINS" && -n "$HOST" ]] || { echo "Could not decode license payload."; exit 1; }

  set_env_key LICENSE_KEY "$KEY"
  set_env_key LICENSE_ADMIN_IDS "$ADMINS"
  set_env_key LICENSE_DASH_HOST "$HOST"
  set_env_key LICENSE_REQUIRE "1"
  set_env_key ADMIN_TELEGRAM_IDS "$ADMINS"
  # Align dashboard domain if empty
  if [[ -z "$(env_get DASH_DOMAIN 2>/dev/null || true)" ]]; then
    set_env_key DASH_DOMAIN "$HOST"
  fi
  echo "License bound:"
  echo "  admins: $ADMINS"
  echo "  host:   $HOST"
  echo "Syncing DB admin roles…"
  (
    cd "$DIR"
    set -a
    # shellcheck disable=SC1091
    source "$ENV_FILE"
    set +a
    if [[ -x "$DIR/node_modules/.bin/tsx" ]]; then
      "$DIR/node_modules/.bin/tsx" apps/server/scripts/set-admin.ts "$ADMINS"
    else
      npx --yes tsx apps/server/scripts/set-admin.ts "$ADMINS"
    fi
  ) || echo "Warning: DB sync failed — .env was still updated."
  echo "Restarting…"
  svc_restart
  sleep 1
  echo "Done. Licensed admin(s) should /start the bot."
}

print_usage() {
  cat <<EOF
${BOLD}QuadTwo (Q2)${NC} — manage bot & dashboard

Usage:
  q2                 Interactive menu
  q2 start           Start services
  q2 stop            Stop services
  q2 restart         Restart services
  q2 update          Pull & rebuild from GitHub
  q2 status          Service status
  q2 logs            Follow journal logs
  q2 env             Edit .env
  q2 set-token [TOKEN]
  q2 set-admin [ID,...]
  q2 activate [KEY]  Bind license (Telegram admin + dash host)
  q2 license         Show license status
  q2 demo            Demo Bot menu (DEMO_MODE on/off / status)
  q2 demo status|enable|disable

Also available as: ${CYAN}quadtwo${NC}
EOF
}

run_cmd() {
  local cmd="${1:-}"
  shift || true
  case "$cmd" in
    start) svc_start ;;
    stop) svc_stop ;;
    restart) svc_restart ;;
    update) do_update ;;
    status) svc_status ;;
    logs) svc_logs ;;
    env) do_env ;;
    set-token|settoken) do_set_token "${1:-}" ;;
    set-admin|setadmin) do_set_admin "${1:-}" ;;
    activate) do_activate "${1:-}" ;;
    license|lic) do_license_status ;;
    demo) do_demo "$@" ;;
    help|-h|--help) print_usage ;;
    "") return 1 ;;
    *)
      echo "Unknown command: $cmd"
      print_usage
      exit 1
      ;;
  esac
}

pause() {
  echo
  read -r -p "Press Enter to continue…" _ || true
}

show_menu() {
  clear 2>/dev/null || true
  cat <<EOF
${BOLD}${CYAN}╔══════════════════════════╗
║   QuadTwo  ·  Q2         ║
╚══════════════════════════╝${NC}
${DIM}dir: ${DIR}${NC}

  ${GREEN}1${NC}) start
  ${GREEN}2${NC}) stop
  ${GREEN}3${NC}) restart
  ${GREEN}4${NC}) update
  ${GREEN}5${NC}) status
  ${GREEN}6${NC}) logs
  ${GREEN}7${NC}) env
  ${GREEN}8${NC}) set-token  ${DIM}[TOKEN]${NC}
  ${GREEN}9${NC}) set-admin  ${DIM}[ID,...]${NC}
  ${GREEN}a${NC}) activate   ${DIM}[license key]${NC}
  ${GREEN}l${NC}) license status
  ${GREEN}d${NC}) demo bot   ${DIM}(DEMO_MODE)${NC}
  ${YELLOW}0${NC}) exit

EOF
  read -r -p "Select [0-9/a/l/d]: " choice || true
  case "${choice:-}" in
    1) run_cmd start; pause ;;
    2) run_cmd stop; pause ;;
    3) run_cmd restart; pause ;;
    4) run_cmd update; pause ;;
    5) run_cmd status; pause ;;
    6)
      echo -e "${DIM}Ctrl+C to stop following logs${NC}"
      run_cmd logs || true
      pause
      ;;
    7) run_cmd env; pause ;;
    8)
      read -r -p "BOT_TOKEN (Enter to prompt later): " tok || true
      run_cmd set-token "${tok:-}"
      pause
      ;;
    9)
      read -r -p "Admin ID(s) comma-separated (Enter to prompt): " ids || true
      run_cmd set-admin "${ids:-}"
      pause
      ;;
    a|A)
      read -r -p "License key (Enter to paste next): " key || true
      run_cmd activate "${key:-}"
      pause
      ;;
    l|L) run_cmd license; pause ;;
    d|D) run_cmd demo ;;
    0|q|Q|exit) echo "Bye."; exit 0 ;;
    *)
      echo "Invalid option."
      pause
      ;;
  esac
}

main() {
  if [[ $# -eq 0 ]]; then
    while true; do
      show_menu
    done
  else
    run_cmd "$@"
  fi
}

main "$@"
