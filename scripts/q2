#!/usr/bin/env bash
# QuadTwo (Q2) management CLI
# Usage:
#   q2                 # interactive menu
#   q2 start|stop|…    # direct command
#   quadtwo …          # same binary (symlink)
set -euo pipefail

SERVICE="${QUADTWO_SERVICE:-quadtwo}"
WEB_SERVICE="${SERVICE}-web"
DIR="${QUADTWO_DIR:-/opt/quadtwo}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

has_web() { systemctl list-unit-files "${WEB_SERVICE}.service" &>/dev/null; }

svc_start() {
  systemctl start "$SERVICE"
  has_web && systemctl start "$WEB_SERVICE" || true
  echo -e "${GREEN}Started${NC} ${SERVICE}${has_web:+ + ${WEB_SERVICE}}"
}

svc_stop() {
  has_web && systemctl stop "$WEB_SERVICE" || true
  systemctl stop "$SERVICE"
  echo -e "${YELLOW}Stopped${NC} ${SERVICE}${has_web:+ + ${WEB_SERVICE}}"
}

svc_restart() {
  systemctl restart "$SERVICE"
  has_web && systemctl restart "$WEB_SERVICE" || true
  echo -e "${GREEN}Restarted${NC} ${SERVICE}${has_web:+ + ${WEB_SERVICE}}"
}

svc_status() {
  systemctl status "$SERVICE" --no-pager || true
  if has_web; then
    echo
    systemctl status "$WEB_SERVICE" --no-pager || true
  fi
}

svc_logs() {
  if has_web; then
    journalctl -u "$SERVICE" -u "$WEB_SERVICE" -f -n 100
  else
    journalctl -u "$SERVICE" -f -n 100
  fi
}

env_file() { echo "$DIR/.env"; }

env_get() {
  local key="$1" file
  file="$(env_file)"
  [[ -f "$file" ]] || return 1
  grep -E "^${key}=" "$file" | tail -n1 | cut -d= -f2- | tr -d '\r'
}

set_env_key() {
  local key="$1" value="$2" file tmp
  file="$(env_file)"
  [[ -f "$file" ]] || { echo "No .env at $file"; exit 1; }
  tmp="$(mktemp)"
  grep -v -E "^${key}=" "$file" > "$tmp" || true
  printf '%s=%s\n' "$key" "$value" >> "$tmp"
  mv "$tmp" "$file"
  chmod 600 "$file"
}

telegram_get_me() {
  local token="$1" proxy args=(-fsS --max-time 15)
  proxy="$(env_get TELEGRAM_PROXY 2>/dev/null || true)"
  [[ -n "$proxy" ]] && args+=(-x "$proxy")
  curl "${args[@]}" "https://api.telegram.org/bot${token}/getMe"
}

do_update() {
  bash <(curl -Ls https://raw.githubusercontent.com/Peymantia/quadtwo/main/install.sh) --update
}

do_env() {
  ${EDITOR:-nano} "$(env_file)"
}

do_set_token() {
  local TOKEN="${1:-}"
  local ENV_FILE ME_JSON BOT_USER BOT_NAME DOMAIN PATH_HOOK WEBHOOK_URL
  ENV_FILE="$(env_file)"
  [[ -f "$ENV_FILE" ]] || { echo "No .env at $ENV_FILE"; exit 1; }
  if [[ -z "$TOKEN" ]]; then
    read -r -p "New BOT_TOKEN from BotFather: " TOKEN
  fi
  TOKEN="$(echo "$TOKEN" | tr -d '[:space:]')"
  [[ -n "$TOKEN" ]] || { echo "BOT_TOKEN is required."; exit 1; }
  if [[ ! "$TOKEN" =~ ^[0-9]+:[A-Za-z0-9_-]+$ ]]; then
    echo "Token format looks invalid (expected 123456789:ABC...)."
    exit 1
  fi
  echo "Validating token with Telegram..."
  ME_JSON="$(telegram_get_me "$TOKEN")" || {
    echo "Telegram rejected this token (network or invalid token)."
    exit 1
  }
  BOT_USER="$(echo "$ME_JSON" | grep -o '"username":"[^"]*"' | head -1 | cut -d'"' -f4 || true)"
  BOT_NAME="$(echo "$ME_JSON" | grep -o '"first_name":"[^"]*"' | head -1 | cut -d'"' -f4 || true)"
  set_env_key BOT_TOKEN "$TOKEN"
  echo "BOT_TOKEN updated in $ENV_FILE"
  if [[ "$(env_get BOT_MODE)" == "webhook" ]]; then
    DOMAIN="$(env_get PUBLIC_DOMAIN)"
    PATH_HOOK="$(env_get TELEGRAM_WEBHOOK_PATH)"
    PATH_HOOK="${PATH_HOOK:-/telegram/webhook}"
    if [[ -n "$DOMAIN" ]]; then
      WEBHOOK_URL="https://${DOMAIN}${PATH_HOOK}"
      echo "Setting webhook: $WEBHOOK_URL"
      curl -fsS --max-time 15 \
        "https://api.telegram.org/bot${TOKEN}/setWebhook" \
        -d "url=${WEBHOOK_URL}" >/dev/null \
        || echo "Warning: setWebhook failed — check PUBLIC_DOMAIN and HTTPS."
    else
      echo "Warning: BOT_MODE=webhook but PUBLIC_DOMAIN is empty."
    fi
  fi
  echo "Restarting services..."
  svc_restart
  sleep 1
  if [[ -n "$BOT_USER" ]]; then
    echo "Done. New bot: @${BOT_USER}${BOT_NAME:+ ($BOT_NAME)}"
  else
    echo "Done. Service restarted."
  fi
  echo "Users must open the new bot and send /start."
}

do_set_admin() {
  local IDS="${1:-}" OLD_IDS ENV_FILE
  ENV_FILE="$(env_file)"
  [[ -f "$ENV_FILE" ]] || { echo "No .env at $ENV_FILE"; exit 1; }
  if [[ -z "$IDS" ]]; then
    echo "Current ADMIN_TELEGRAM_IDS: $(env_get ADMIN_TELEGRAM_IDS || echo '(empty)')"
    read -r -p "New admin Telegram numeric ID(s), comma-separated: " IDS
  fi
  IDS="$(echo "$IDS" | tr -d '[:space:]' | tr -d '@')"
  [[ -n "$IDS" ]] || { echo "Admin Telegram ID is required."; exit 1; }
  if [[ ! "$IDS" =~ ^[0-9]+(,[0-9]+)*$ ]]; then
    echo "Invalid ID list (expected numeric IDs like 123456789 or 111,222)."
    exit 1
  fi
  OLD_IDS="$(env_get ADMIN_TELEGRAM_IDS || true)"
  set_env_key ADMIN_TELEGRAM_IDS "$IDS"
  echo "ADMIN_TELEGRAM_IDS: ${OLD_IDS:-'(empty)'} → $IDS"
  echo "Syncing database roles..."
  (
    cd "$DIR"
    set -a
    # shellcheck disable=SC1091
    source "$ENV_FILE"
    set +a
    if [[ -x "$DIR/node_modules/.bin/tsx" ]]; then
      "$DIR/node_modules/.bin/tsx" apps/server/scripts/set-admin.ts "$IDS"
    elif command -v npx >/dev/null 2>&1; then
      npx --yes tsx apps/server/scripts/set-admin.ts "$IDS"
    else
      echo "Warning: tsx not found — .env updated but DB roles were not synced."
      echo "Run manually: cd $DIR && npx tsx apps/server/scripts/set-admin.ts $IDS"
    fi
  ) || {
    echo "Warning: DB sync failed — .env was still updated."
    echo "Fix DB with: cd $DIR && npx tsx apps/server/scripts/set-admin.ts $IDS"
  }
  echo "Restarting services..."
  svc_restart
  sleep 1
  echo "Done. New admin(s): $IDS"
  echo "Open the bot from the new Telegram account and send /start."
  echo "Old Telegram accounts are no longer control admins."
}

print_usage() {
  cat <<EOF
${BOLD}QuadTwo (Q2)${NC} — manage bot & dashboard

Usage:
  q2                 Interactive menu
  q2 start           Start services
  q2 stop            Stop services
  q2 restart         Restart services
  q2 update          Pull & rebuild from GitHub
  q2 status          Service status
  q2 logs            Follow journal logs
  q2 env             Edit .env
  q2 set-token [TOKEN]
  q2 set-admin [ID,...]

Also available as: ${CYAN}quadtwo${NC}
EOF
}

run_cmd() {
  local cmd="${1:-}"
  shift || true
  case "$cmd" in
    start) svc_start ;;
    stop) svc_stop ;;
    restart) svc_restart ;;
    update) do_update ;;
    status) svc_status ;;
    logs) svc_logs ;;
    env) do_env ;;
    set-token|settoken) do_set_token "${1:-}" ;;
    set-admin|setadmin) do_set_admin "${1:-}" ;;
    help|-h|--help) print_usage ;;
    "") return 1 ;;
    *)
      echo "Unknown command: $cmd"
      print_usage
      exit 1
      ;;
  esac
}

pause() {
  echo
  read -r -p "Press Enter to continue…" _ || true
}

show_menu() {
  clear 2>/dev/null || true
  cat <<EOF
${BOLD}${CYAN}╔══════════════════════════╗
║   QuadTwo  ·  Q2         ║
╚══════════════════════════╝${NC}
${DIM}dir: ${DIR}${NC}

  ${GREEN}1${NC}) start
  ${GREEN}2${NC}) stop
  ${GREEN}3${NC}) restart
  ${GREEN}4${NC}) update
  ${GREEN}5${NC}) status
  ${GREEN}6${NC}) logs
  ${GREEN}7${NC}) env
  ${GREEN}8${NC}) set-token  ${DIM}[TOKEN]${NC}
  ${GREEN}9${NC}) set-admin  ${DIM}[ID,...]${NC}
  ${YELLOW}0${NC}) exit

EOF
  read -r -p "Select [0-9]: " choice || true
  case "${choice:-}" in
    1) run_cmd start; pause ;;
    2) run_cmd stop; pause ;;
    3) run_cmd restart; pause ;;
    4) run_cmd update; pause ;;
    5) run_cmd status; pause ;;
    6)
      echo -e "${DIM}Ctrl+C to stop following logs${NC}"
      run_cmd logs || true
      pause
      ;;
    7) run_cmd env; pause ;;
    8)
      read -r -p "BOT_TOKEN (Enter to prompt later): " tok || true
      run_cmd set-token "${tok:-}"
      pause
      ;;
    9)
      read -r -p "Admin ID(s) comma-separated (Enter to prompt): " ids || true
      run_cmd set-admin "${ids:-}"
      pause
      ;;
    0|q|Q|exit) echo "Bye."; exit 0 ;;
    *)
      echo "Invalid option."
      pause
      ;;
  esac
}

main() {
  if [[ $# -eq 0 ]]; then
    while true; do
      show_menu
    done
  else
    run_cmd "$@"
  fi
}

main "$@"
