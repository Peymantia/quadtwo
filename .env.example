# Server
NODE_ENV=development
PORT=4000
DATABASE_URL=file:./prisma/dev.db

# Telegram
BOT_TOKEN=
BOT_MODE=polling
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
ADMIN_TELEGRAM_IDS=

# 3x-ui (same server → use http://127.0.0.1:PANEL_PORT/BASE_PATH/)
# Create token: Panel → Settings → Security → API Token
XUI_BASE_URL=http://127.0.0.1:2053/
XUI_API_TOKEN=
XUI_INBOUND_ID=1
XUI_SUB_BASE=

# اگر api.telegram.org مستقیم باز نیست (مثلاً از ایران):
# TELEGRAM_PROXY=http://127.0.0.1:7890

# Web
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000
PUBLIC_DOMAIN=app.piing.ir
